RewriteEngine On

# If the request is for an existing file or directory, serve it directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Root index
RewriteRule ^$ index.php [L]

# Pretty URLs for internal pages
RewriteRule ^about-me/?$ about-me.php [L]
RewriteRule ^coding-examples/?$ coding-examples.php [L]
RewriteRule ^scion-scheme/?$ scion-scheme.php [L]

# Custom 404 page
ErrorDocument 404 /404.php
